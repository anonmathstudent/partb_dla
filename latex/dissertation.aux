\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Comparison of Ordinary Least Squares (L2) and Theil-Sen (TS) regressions for extracting the Box-Counting dimension of a single DLA cluster. To directly yield the fractal dimension $D_0$ as a positive gradient, the data is plotted as $\log N(\epsilon )$ against $\log (1/\epsilon )$. The annotated metric $\Delta D = |D_{L2} - D_{TS}|$ quantifies the discrepancy between the two statistical estimators. Including boxes that are too small or large relative to the cluster can have significant effects on the resulting dimension statistic.}}{26}{figure.caption.7}\protected@file@percent }
\newlabel{fig:box_regression_robustness}{{5.1}{26}{Comparison of Ordinary Least Squares (L2) and Theil-Sen (TS) regressions for extracting the Box-Counting dimension of a single DLA cluster. To directly yield the fractal dimension $D_0$ as a positive gradient, the data is plotted as $\log N(\epsilon )$ against $\log (1/\epsilon )$. The annotated metric $\Delta D = |D_{L2} - D_{TS}|$ quantifies the discrepancy between the two statistical estimators. Including boxes that are too small or large relative to the cluster can have significant effects on the resulting dimension statistic}{figure.caption.7}{}}
\newlabel{fig:box_regression_robustness@cref}{{[figure][1][5]5.1}{[1][26][]26}}
