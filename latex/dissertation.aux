\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Coarse-grained spatial density maps for representative $10^7$-particle clusters across the three simulation models. To visualise the localised mass concentration, the spatial bounding box of each cluster is discretised into a high-resolution 2D grid ($2^{11} \times 2^{11}$ pixels). A spatial histogram is computed by counting the exact number of particles occupying each discrete pixel bin, with empty bins masked for clarity. A linear colour scale is applied to the resulting particle counts, where darker regions indicate an proportionately higher local mass density. }}{22}{figure.caption.5}\protected@file@percent }
\newlabel{fig:heatmap_comparison}{{4.1}{22}{Coarse-grained spatial density maps for representative $10^7$-particle clusters across the three simulation models. To visualise the localised mass concentration, the spatial bounding box of each cluster is discretised into a high-resolution 2D grid ($2^{11} \times 2^{11}$ pixels). A spatial histogram is computed by counting the exact number of particles occupying each discrete pixel bin, with empty bins masked for clarity. A linear colour scale is applied to the resulting particle counts, where darker regions indicate an proportionately higher local mass density}{figure.caption.5}{}}
\newlabel{fig:heatmap_comparison@cref}{{[figure][1][4]4.1}{[1][22][]22}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Spatial density maps of the simulated models at $10^6$ and $10^7$ scales. Unlike the single-cluster heatmaps, these visualisations aggregate the entire ensemble of simulated clusters into a unified 2D spatial histogram. The logarithmic colour intensity represents the cumulative frequency of particles occupying each spatial bin. Overlay contours denote the maximum absolute radial extent (dashed cyan) and the average radial mass distribution (solid white), also known as the radius of gyration $R_g$. }}{23}{figure.caption.6}\protected@file@percent }
\newlabel{fig:density_comparison}{{4.2}{23}{Spatial density maps of the simulated models at $10^6$ and $10^7$ scales. Unlike the single-cluster heatmaps, these visualisations aggregate the entire ensemble of simulated clusters into a unified 2D spatial histogram. The logarithmic colour intensity represents the cumulative frequency of particles occupying each spatial bin. Overlay contours denote the maximum absolute radial extent (dashed cyan) and the average radial mass distribution (solid white), also known as the radius of gyration $R_g$}{figure.caption.6}{}}
\newlabel{fig:density_comparison@cref}{{[figure][2][4]4.2}{[1][22][]23}}
